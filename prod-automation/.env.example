# ── MongoDB Atlas ─────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://cortex:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=byoc_platform


# ── Pulumi S3 Backend ────────────────────────────────────────────
PULUMI_BACKEND_URL=s3://cortex-pulumi-state?region=us-east-1
PULUMI_SECRETS_PROVIDER=awskms://alias/pulumi-secrets?region=us-east-1

# ── Auth / JWT ────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN_HOURS=168
CORS_ORIGINS=http://localhost:3000

# ── Flower (Celery monitoring dashboard) ─────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=changeme

# ── Platform domain (for nginx/certbot) ──────────────────────────
PLATFORM_DOMAIN=platform.usecortex.opengig.work

# AWS credentials (IAM user that can assume customer roles)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Pulumi S3 backend (state storage)
PULUMI_BACKEND_URL=s3://my-pulumi-state-bucket?region=us-east-1
PULUMI_SECRETS_PROVIDER=awskms://arn:aws:kms:us-east-1:ACCOUNT_ID:alias/pulumi-secrets

# Passphrase for secrets encryption (alternative to KMS)
# PULUMI_CONFIG_PASSPHRASE=my-secret-passphrase

# Working directory for Pulumi project (where Pulumi.yaml lives)
PULUMI_WORK_DIR=.

# GitHub (for GitOps values writer)
GITHUB_PAT=ghp_xxxxxxxxxxxx
GITHUB_REPO=opengig/cortex
GITHUB_BRANCH=main

# Platform-managed secrets
FALKORDB_PASSWORD=d6c77M05pV
MILVUS_TOKEN=root:Milvus

# NextJS platform secrets
NEXTJS_NEXTAUTH_SECRET=some-secret-next-auth
NEXTJS_GOOGLE_CLIENT_ID=
NEXTJS_GOOGLE_CLIENT_SECRET=
NEXTJS_AUTH_DYNAMODB_ID=
NEXTJS_AUTH_DYNAMODB_SECRET=
NEXTJS_AWS_CONFIG=
NEXTJS_MCP_ENCRYPTION_KEY=
NEXTJS_RESEND_API_KEY=
NEXTJS_STRIPE_SECRET_KEY=
NEXTJS_FRONTEND_CONFIG=
NEXTJS_NEXTAUTH_URL=http://localhost:3000
NEXTJS_AUTH_DYNAMODB_REGION=us-east-1
NEXTJS_EMAIL_FROM=

# AI API keys (platform-managed)
GOOGLE_API_KEY=
GEMINI_API_KEY=
